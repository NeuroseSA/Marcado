@page "/agenda"
@using System.ComponentModel.DataAnnotations
@using Marcado.Core.Entidades
@using Marcado.Core.Servicos
@using Marcado.Core.Servicos.Interfaces
@using Marcado.App.Helpers
@using Marcado.App.Services
@using System.Threading.Tasks
@using System.Security.AccessControl
@inject IClientesServico _clientesServico
@inject IAgendamentoServico _agendamentoServico
@inject IConfiguracaoHorarioServico _configuracaoServico
@inject FeedbackService _feedbackService

<link href="css/agenda.css" rel="stylesheet" />

<PageTitle>Agenda</PageTitle>

<div class="page-container">
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Agenda</h2>
            <div class="actions">
                <button class="btn btn-outline" @onclick="DiaAnterior">← Anterior</button>
                <InputDate @bind-Value="DataSelecionada" class="input-date" />
                <button class="btn btn-outline" @onclick="ProximoDia">Próximo →</button>

                <select class="select" @bind="ModoVisualizacao" @bind:after="OnModoVisualizacaoChanged">
                    <option value="diaria">Visão Diária</option>
                    <option value="mensal">Visão Mensal</option>
                </select>

                <button class="btn btn-success" @onclick="AbrirDia">Abrir Dia</button>
                <button class="btn btn-secondary" @onclick="FecharDia">Fechar Dia</button>
                <button class="btn btn-primary" @onclick="NovoAgendamento">+ Novo Agendamento</button>
            </div>
        </div>

        @if (!diaAtual_ativo)
        {
            <div class="alert alert-warning">
                <strong>⚠️ Dia Inativo</strong> - Este dia da semana está desabilitado nas configurações. 
                <a href="/config/horarios" class="alert-link">Clique aqui para configurar</a>
            </div>
        }

        @if (ModoVisualizacao == "diaria")
        {
            <div class="agenda-grid">
                @foreach (var slot in agendaSlots)
                {
                    <div class="agenda-slot @(slot.Status.ToLower())" @onclick="async () => await CliqueSlot(slot)">
                        <span class="hora">@slot.Hora:00</span>
                        <div class="descricao">
                            @if (slot.Status == "Agendado" || slot.Status == "Realizado")
                            {
                                <strong>@slot.Cliente?.Nome</strong><br />
                                <span>@slot.Descricao</span>
                            }
                            else
                            {
                                <span>@slot.Descricao</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else if (ModoVisualizacao == "mensal")
        {
            <div class="calendario-mensal">
                <!-- Cabeçalho com os dias da semana -->
                <div class="calendario-header">
                    <div class="dia-semana">DOM</div>
                    <div class="dia-semana">SEG</div>
                    <div class="dia-semana">TER</div>
                    <div class="dia-semana">QUA</div>
                    <div class="dia-semana">QUI</div>
                    <div class="dia-semana">SEX</div>
                    <div class="dia-semana">SÁB</div>
                </div>

                <!-- Grid do calendário -->
                <div class="calendario-grid">
                    @{
                        var primeiroDiaMes = new DateTime(DataSelecionada.Year, DataSelecionada.Month, 1);
                        var ultimoDiaMes = new DateTime(DataSelecionada.Year, DataSelecionada.Month, DateTime.DaysInMonth(DataSelecionada.Year, DataSelecionada.Month));
                        
                        // Calcular quantos dias do mês anterior mostrar
                        var diasAntesDoInicio = (int)primeiroDiaMes.DayOfWeek;
                        var dataInicio = primeiroDiaMes.AddDays(-diasAntesDoInicio);
                        
                        // Calcular quantos dias do próximo mês mostrar
                        var diasDepoisDoFim = 6 - (int)ultimoDiaMes.DayOfWeek;
                        var dataFim = ultimoDiaMes.AddDays(diasDepoisDoFim);
                        
                        // Preencher o calendário
                        for (var data = dataInicio; data <= dataFim; data = data.AddDays(1))
                        {
                            var diaSelecaoMensal = data;
                            var isDoMesAtual = data.Month == DataSelecionada.Month;
                            var progressoDia = isDoMesAtual ? ObterProgressoDia(data) : null;
                            var cssClass = GetCssClassesDia(data, isDoMesAtual, progressoDia);
                            
                            <div class="@cssClass" @onclick="() => SelecionarDiaCalendario(diaSelecaoMensal, isDoMesAtual)">
                                <div class="dia-numero">
                                    @data.Day
                                </div>
                                
                                @if (isDoMesAtual && progressoDia != null)
                                {
                                    <div class="dia-conteudo">
                                        @if (progressoDia.TipoStatus != StatusDia.Inativo)
                                        {
                                            <div class="barra-progresso-mini">
                                                <div class="progresso-fill-mini" 
                                                     style="width: @(progressoDia.Percentual)%; background: @(ObterCorProgresso(progressoDia))"></div>
                                            </div>
                                        }
                                        
                                        <div class="status-indicator">
                                            <span class="badge-mini @(progressoDia.StatusCss)">
                                                @progressoDia.StatusTexto
                                            </span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>


    @* Modal de agendamento *@
    @if (mostrarModal)
    {
        <link href="css/agenda-modal.css" rel="stylesheet" />
        <div class="modal-overlay" @onclick="FecharModal">
            <div class="modal-content" @onclick:stopPropagation="true">
                <button class="modal-close" @onclick="FecharModal" aria-label="Fechar modal">×</button>
                <h3 class="modal-title">@(modoEdicao ? "Editar Agendamento" : "Novo Agendamento")</h3>

                <div class="modal-field">
                    <label class="modal-label">Cliente *</label>
                    <div class="autocomplete-container">
                        <input type="text"
                               @bind="clienteBusca"
                               @bind:event="oninput"
                               @bind:after="BuscarClientes"
                               @onfocus="MostrarListaClientes"
                               @onblur="OcultarListaClientes"
                               placeholder="Digite o nome do cliente"
                               class="modal-input autocomplete-input"
                               autocomplete="off" />

                        @if (mostrarListaClientes && clientes.Any())
                        {
                            <div class="autocomplete-dropdown">
                                @foreach (var cliente in clientes.Take(8))
                                {
                                    <div class="autocomplete-item"
                                         @onmousedown="() => SelecionarCliente(cliente)"
                                         @onmousedown:preventDefault="true">
                                        <div class="cliente-nome">@cliente.Nome</div>
                                        <div class="cliente-info">@FormatacaoHelper.FormatarTelefone(cliente.Telefone) - @cliente.Email</div>
                                    </div>
                                }
                            </div>
                        }

                        @if (mostrarListaClientes && !clientes.Any() && !string.IsNullOrWhiteSpace(clienteBusca))
                        {
                            <div class="autocomplete-dropdown">
                                <div class="autocomplete-item no-results">
                                    Nenhum cliente encontrado
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="modal-row">
                    <div class="modal-col">
                        <label class="modal-label">Data</label>
                        <input type="date" @bind="novoAgendamento.Data" @bind:format="yyyy-MM-dd" class="modal-input" />
                    </div>

                    <div class="modal-col">
                        <label class="modal-label">Hora</label>
                        <select @bind="novoAgendamento.Hora" class="modal-input">
                            @foreach (var hora in GerarHorasDisponiveis())
                            {
                                @if (!VerificarHoraDisponivel(hora))
                                {
                                    <option value="@hora" disabled style="text-decoration: line-through; color: #941111;">@hora:00</option>
                                }
                                else
                                {
                                    <option value="@hora">@hora:00</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="modal-field">
                    <label class="modal-label">Descrição</label>
                    <textarea @bind="novoAgendamento.Descricao" rows="3" placeholder="Descrição do agendamento"
                        class="modal-textarea"></textarea>
                </div>

                <div class="modal-actions">
                    @if (modoEdicao && novoAgendamento.Status != "Realizado")
                    {
                        <button @onclick="CancelarAgendamento" class="modal-btn modal-btn-delete">
                            Cancelar
                        </button>
                        <button @onclick="MarcarComoRealizado" class="modal-btn modal-btn-realizado">
                            Realizado
                        </button>
                    }
                    <button @onclick="SalvarAgendamento" class="modal-btn modal-btn-save">
                        @(modoEdicao ? "Atualizar" : "Salvar")
                    </button>
                </div>
            </div>
        </div>
    }

</div>


@code {
    private DateTime DataSelecionada = DateTime.Today;
    private string ModoVisualizacao = "diaria"; // mensal, diaria
    private bool mostrarModal = false;
    private bool modoEdicao = false;
    private NovoAgendamentoModel novoAgendamento = new NovoAgendamentoModel();
    private List<Cliente> clientes = new List<Cliente>();

    // Propriedades para o autocomplete
    private string clienteBusca = string.Empty;
    private bool mostrarListaClientes = false;
    private Cliente? clienteSelecionado = null;

    private List<AgendaSlot> agendaSlots = new();
    private HashSet<DateTime> DiasFechados = new();
    
    // Configurações de horário
    private ConfiguracaoHorario? configuracaoHorario;
    private TimeSpan horaInicio = new(8, 0, 0);
    private TimeSpan horaFim = new(18, 0, 0);
    private int intervaloSlots = 60;
    private bool diaAtual_ativo = true;

    protected override async Task OnInitializedAsync()
    {
        await CarregarConfiguracoes();
        await CarregarSlots();
        await CarregarAgendamentosMes();
    }

    private async Task CarregarConfiguracoes()
    {
        try
        {
            configuracaoHorario = await _configuracaoServico.ObterConfiguracaoAsync(1); // TODO: Usar ID do usuário logado
            
            if (configuracaoHorario != null)
            {
                horaInicio = configuracaoHorario.HoraInicio;
                horaFim = configuracaoHorario.HoraFim;
                intervaloSlots = configuracaoHorario.IntervaloSlots;
            }
        }
        catch (Exception ex)
        {
            _feedbackService.MostrarErro("Erro", $"Não foi possível carregar as configurações: {ex.Message}");
        }
    }

    private async Task CarregarSlots()
    {
        agendaSlots.Clear();
        
        // Verificar se o dia está ativo
        diaAtual_ativo = await VerificarDiaAtivo(DataSelecionada);
        
        if (!diaAtual_ativo)
        {
            StateHasChanged();
            return;
        }

        // Gerar slots baseados na configuração
        var horasDisponiveis = GerarHorasDisponiveis();
        foreach (var hora in horasDisponiveis)
        {
            agendaSlots.Add(new AgendaSlot
            {
                Hora = hora,
                Status = "Livre",
                Descricao = ""
            });
        }

        var agentamentos = await _agendamentoServico.ObterAgendamentosAsync(1, DataSelecionada);
        foreach (var agendamento in agentamentos)
        {
            var slot = agendaSlots.FirstOrDefault(s => s.Hora == agendamento.Hora);
            if (slot != null)
            {
                slot.Status = agendamento.Status;
                slot.Descricao = agendamento.Servico;
                slot.Cliente = agendamento.Cliente;
                slot.AgendamentoId = agendamento.Id;
            }
        }

        StateHasChanged();
    }

    private async Task<bool> VerificarDiaAtivo(DateTime data)
    {
        if (configuracaoHorario == null) return true; // Se não há configuração, permite todos os dias

        return data.DayOfWeek switch
        {
            DayOfWeek.Monday => configuracaoHorario.SegundaAtiva,
            DayOfWeek.Tuesday => configuracaoHorario.TercaAtiva,
            DayOfWeek.Wednesday => configuracaoHorario.QuartaAtiva,
            DayOfWeek.Thursday => configuracaoHorario.QuintaAtiva,
            DayOfWeek.Friday => configuracaoHorario.SextaAtiva,
            DayOfWeek.Saturday => configuracaoHorario.SabadoAtiva,
            DayOfWeek.Sunday => configuracaoHorario.DomingoAtiva,
            _ => false
        };
    }

    private List<int> GerarHorasDisponiveis()
    {
        var horas = new List<int>();
        
        // Converter TimeSpan para horas inteiras
        var horaInicioInt = horaInicio.Hours;
        var horaFimInt = horaFim.Hours;
        
        // Gerar slots baseados no intervalo configurado
        if (intervaloSlots == 60)
        {
            // Intervalos de 1 hora
            for (int h = horaInicioInt; h < horaFimInt; h++)
            {
                horas.Add(h);
            }
        }
        else if (intervaloSlots == 30)
        {
            // Intervalos de 30 minutos - por enquanto vamos manter só horas inteiras
            // TODO: Implementar suporte a 30 minutos futuramente
            for (int h = horaInicioInt; h < horaFimInt; h++)
            {
                horas.Add(h);
            }
        }
        else
        {
            // Para outros intervalos, usar horas inteiras
            for (int h = horaInicioInt; h < horaFimInt; h += (intervaloSlots / 60))
            {
                if (h < horaFimInt)
                {
                    horas.Add(h);
                }
            }
        }
        
        return horas;
    }

    private bool VerificarDiaAtivoSincrono(DateTime data)
    {
        if (configuracaoHorario == null) return true; // Se não há configuração, permite todos os dias

        return data.DayOfWeek switch
        {
            DayOfWeek.Monday => configuracaoHorario.SegundaAtiva,
            DayOfWeek.Tuesday => configuracaoHorario.TercaAtiva,
            DayOfWeek.Wednesday => configuracaoHorario.QuartaAtiva,
            DayOfWeek.Thursday => configuracaoHorario.QuintaAtiva,
            DayOfWeek.Friday => configuracaoHorario.SextaAtiva,
            DayOfWeek.Saturday => configuracaoHorario.SabadoAtiva,
            DayOfWeek.Sunday => configuracaoHorario.DomingoAtiva,
            _ => false
        };
    }

    private async Task OnModoVisualizacaoChanged()
    {
        if (ModoVisualizacao == "diaria")
        {
            await CarregarSlots();
        }
        else if (ModoVisualizacao == "mensal")
        {
            await CarregarAgendamentosMes();
        }
        StateHasChanged();
    }

    private async Task DiaAnterior()
    {
        DataSelecionada = ModoVisualizacao == "mensal"
            ? DataSelecionada.AddMonths(-1)
            : DataSelecionada.AddDays(-1);

        await CarregarSlots();

        if (ModoVisualizacao == "diaria")
            await CarregarSlots();
        
        StateHasChanged();
    }

    private async Task ProximoDia()
    {
        DataSelecionada = ModoVisualizacao == "mensal"
            ? DataSelecionada.AddMonths(1)
            : DataSelecionada.AddDays(1);

        if (ModoVisualizacao == "diaria")
        {
            await CarregarSlots();
        }
        StateHasChanged();
    }

    private async Task FecharDia()
    {
        var agendamentosAtivos = agendaSlots.Where(x => x.Status == "Agendado").ToList();

        if (!DiasFechados.Contains(DataSelecionada.Date))
            DiasFechados.Add(DataSelecionada.Date);

        foreach (var slot in agendaSlots)
        {
            if (slot.Status != "Agendado")
            {
                await _agendamentoServico.AgendarServicoAsync(new Agendamento
                {
                    ClienteId = null,
                    UsuarioId = 1, // TODO: substituir pelo ID do usuário logado
                    Data = DataSelecionada,
                    Hora = slot.Hora,
                    Servico = "Agenda Fechada",
                    Status = "Fechado"
                });
            }
        }

        if (agendamentosAtivos.Any())
        {
            var quantidadeAgendamentos = agendamentosAtivos.Count;
            var mensagem = quantidadeAgendamentos == 1 
                ? "Existe 1 agendamento ativo para este dia. O restante a agenda foi fechada!"
                : $"Existem {quantidadeAgendamentos} agendamentos ativos para este dia. O restante a agenda foi fechada!";

            _feedbackService.MostrarAlerta(
                "Atenção!", 
                mensagem,
                8000 // 8 segundos para dar tempo de ler
            );
        }
        else
        {
            _feedbackService.MostrarSucesso(
                "Dia Fechado!",
                $"A agenda do dia {DataSelecionada.ToString("dd/MM/yyyy")} foi fechada com sucesso."
            );
        }

        await CarregarSlots();
        StateHasChanged();
    }

    private async Task AbrirDia()
    {
        if (DiasFechados.Contains(DataSelecionada.Date))
            DiasFechados.Remove(DataSelecionada.Date);

        foreach (var slot in agendaSlots.Where(x => x.Status == "Fechado" && x.AgendamentoId.HasValue))
        {
            if (slot.AgendamentoId.HasValue)
                await _agendamentoServico.CancelarAgendamentoAsync(slot.AgendamentoId.Value);
        }

        _feedbackService.MostrarSucesso(
            "Dia Aberto!",
            $"A agenda do dia {DataSelecionada.ToString("dd/MM/yyyy")} foi reaberta com sucesso."
        );
        await CarregarSlots();
        StateHasChanged();
    }
    private async Task SelecionarDia(DateTime data)
    {
        // Verificar se o dia está inativo
        if (!VerificarDiaAtivoSincrono(data))
        {
            _feedbackService.MostrarErro(
                "Dia Inativo", 
                "Este dia da semana está desabilitado nas configurações. Para agendar neste dia, primeiro ative-o nas configurações de horários."
            );
            return;
        }

        DataSelecionada = data;
        ModoVisualizacao = "diaria";
        await CarregarSlots();
    }

    private async Task SelecionarDiaCalendario(DateTime data, bool isDoMesAtual)
    {
        if (!isDoMesAtual)
        {
            // Se clicou em um dia de outro mês, navegar para esse mês
            DataSelecionada = data;
            await CarregarSlots();
            await CarregarAgendamentosMes();
            StateHasChanged();
        }
        else
        {
            // Mesmo comportamento do SelecionarDia para dias do mês atual
            await SelecionarDia(data);
        }
    }

    private string GetCssClassesDia(DateTime data, bool isDoMesAtual, ProgressoDia? progressoDia)
    {
        var classes = new List<string> { "calendario-dia" };

        if (!isDoMesAtual)
        {
            classes.Add("outro-mes");
        }
        else
        {
            classes.Add("mes-atual");
            
            if (progressoDia != null)
            {
                switch (progressoDia.TipoStatus)
                {
                    case StatusDia.Inativo:
                        classes.Add("inativo");
                        break;
                    case StatusDia.Fechado:
                        classes.Add("fechado");
                        break;
                    case StatusDia.Completo:
                        classes.Add("completo");
                        break;
                    case StatusDia.Parcial:
                        classes.Add("parcial");
                        break;
                    case StatusDia.Livre:
                        classes.Add("livre");
                        break;
                }
            }
        }

        // Destacar o dia atual
        if (data.Date == DateTime.Today)
        {
            classes.Add("hoje");
        }

        // Destacar o dia selecionado
        if (data.Date == DataSelecionada.Date)
        {
            classes.Add("selecionado");
        }

        return string.Join(" ", classes);
    }

    #region Modal Agendamento
    private async Task NovoAgendamento()
    {
        // Verificar se o dia está ativo
        if (!await VerificarDiaAtivo(DataSelecionada))
        {
            _feedbackService.MostrarErro(
                "Dia Inativo", 
                "Este dia da semana está desabilitado nas configurações. Acesse as configurações para habilitá-lo."
            );
            return;
        }

        modoEdicao = false;
        
        // Definir hora inicial baseada na configuração
        var horasDisponiveis = GerarHorasDisponiveis();
        var horaInicial = horasDisponiveis.FirstOrDefault();
        
        novoAgendamento = new NovoAgendamentoModel
        {
            Data = DataSelecionada,
            Hora = horaInicial
        };

        // Limpar campos do autocomplete
        clienteBusca = string.Empty;
        clienteSelecionado = null;
        clientes.Clear();
        mostrarListaClientes = false;

        mostrarModal = true;
        StateHasChanged();
    }

    private async Task BuscarClientes()
    {
        if (string.IsNullOrWhiteSpace(clienteBusca))
        {
            clientes.Clear();
            mostrarListaClientes = false;
            clienteSelecionado = null;
            novoAgendamento.Cliente = string.Empty;
        }
        else
        {
            try
            {
                clientes = await _clientesServico.BuscarClientesPorFiltroAsync(1, clienteBusca);
                mostrarListaClientes = true;
            }
            catch
            {
                // Log do erro se necessário
                clientes.Clear();
                mostrarListaClientes = false;
            }
        }
        StateHasChanged();
    }

    private void MostrarListaClientes()
    {
        if (!string.IsNullOrWhiteSpace(clienteBusca))
        {
            mostrarListaClientes = true;
            StateHasChanged();
        }
    }

    private async Task OcultarListaClientes()
    {
        // Delay para permitir que o clique no item funcione antes de ocultar
        await Task.Delay(200);
        mostrarListaClientes = false;
        StateHasChanged();
    }

    private void SelecionarCliente(Cliente cliente)
    {
        clienteSelecionado = cliente;
        clienteBusca = cliente.Nome;
        novoAgendamento.Cliente = cliente.Nome;
        mostrarListaClientes = false;
        StateHasChanged();
    }

    private async Task CliqueSlot(AgendaSlot slot)
    {
        // Verificar se o dia está ativo antes de qualquer ação
        if (!await VerificarDiaAtivo(DataSelecionada))
        {
            _feedbackService.MostrarErro(
                "Dia Inativo", 
                "Este dia da semana está desabilitado nas configurações."
            );
            return;
        }

        if (slot.Status == "Livre")
        {
            // Modo novo agendamento
            modoEdicao = false;
            novoAgendamento = new NovoAgendamentoModel
            {
                Data = DataSelecionada,
                Hora = slot.Hora
            };

            // Limpar campos do autocomplete
            clienteBusca = string.Empty;
            clienteSelecionado = null;
            clientes.Clear();
            mostrarListaClientes = false;
        }
        else if ((slot.Status == "Agendado" || slot.Status == "Realizado") && slot.AgendamentoId.HasValue)
        {
            // Modo edição
            modoEdicao = true;
            
            // Carregar dados do agendamento
            var agendamento = await _agendamentoServico.ObterAgendamentoPorIdAsync(slot.AgendamentoId.Value);
            if (agendamento != null)
            {
                novoAgendamento = new NovoAgendamentoModel
                {
                    Id = agendamento.Id,
                    Data = agendamento.Data,
                    Hora = agendamento.Hora,
                    Cliente = agendamento.Cliente?.Nome ?? "",
                    Descricao = agendamento.Servico,
                    Status = agendamento.Status
                };

                clienteSelecionado = agendamento.Cliente;
                clienteBusca = agendamento.Cliente?.Nome ?? "";
                clientes.Clear();
                mostrarListaClientes = false;
            }
        }
        else
        {
            // Slot fechado ou outro status - não fazer nada
            return;
        }

        mostrarModal = true;
        StateHasChanged();
    }

    private void FecharModal()
    {
        mostrarModal = false;
        StateHasChanged();
    }

    private async Task SalvarAgendamento()
    {
        // Validação simples
        if (string.IsNullOrWhiteSpace(novoAgendamento.Cliente) || clienteSelecionado == null)
        {
            _feedbackService.MostrarErro(
                "Erro de Validação",
                "Por favor, selecione um cliente antes de salvar o agendamento."
            );
            return;
        }

        var slot = agendaSlots.FirstOrDefault(s => s.Hora == novoAgendamento.Hora);
        if (slot != null)
        {
            if (modoEdicao && novoAgendamento.Id.HasValue)
            {
                // Atualizar agendamento existente
                var agendamentoExistente = await _agendamentoServico.ObterAgendamentoPorIdAsync(novoAgendamento.Id.Value);
                if (agendamentoExistente != null)
                {
                    agendamentoExistente.ClienteId = clienteSelecionado.Id;
                    agendamentoExistente.Data = novoAgendamento.Data;
                    agendamentoExistente.Hora = novoAgendamento.Hora;
                    agendamentoExistente.Servico = novoAgendamento.Descricao;
                    
                    await _agendamentoServico.AtualizarAgendamentoAsync(agendamentoExistente);
                }
            }
            else
            {
                // Criar novo agendamento
                await _agendamentoServico.AgendarServicoAsync(new Agendamento
                {
                    ClienteId = clienteSelecionado.Id,
                    UsuarioId = 1, // TODO: substituir pelo ID do usuário logado
                    Data = novoAgendamento.Data,
                    Hora = novoAgendamento.Hora,
                    Servico = novoAgendamento.Descricao,
                    Status = "Agendado"
                });
            }
            
            // Recarregar os slots para refletir as mudanças
            await CarregarSlots();
            
            // Mostrar feedback de sucesso
            if (modoEdicao)
            {
                _feedbackService.MostrarSucesso(
                    "Agendamento Atualizado!",
                    $"O agendamento de {clienteSelecionado.Nome} foi atualizado com sucesso."
                );
            }
            else
            {
                _feedbackService.MostrarSucesso(
                    "Agendamento Criado!",
                    $"Agendamento para {clienteSelecionado.Nome} criado com sucesso."
                );
            }
        }

        mostrarModal = false;
        StateHasChanged();
    }
    
    private async Task CancelarAgendamento()
    {
        if (modoEdicao && novoAgendamento.Id.HasValue)
        {
            try
            {
                await _agendamentoServico.CancelarAgendamentoAsync(novoAgendamento.Id.Value);
                await CarregarSlots();
                
                _feedbackService.MostrarSucesso(
                    "Agendamento Cancelado!",
                    "O agendamento foi cancelado com sucesso."
                );
                
                mostrarModal = false;
                StateHasChanged();
            }
            catch (Exception)
            {
                _feedbackService.MostrarErro(
                    "Erro ao Cancelar",
                    "Não foi possível cancelar o agendamento. Tente novamente."
                );
            }
        }
    }

    private async Task MarcarComoRealizado()
    {
        if (modoEdicao && novoAgendamento.Id.HasValue)
        {
            try
            {
                //TODO: Implementar funcionalidade de marcar como realizado
                @* await _agendamentoServico.MarcarComoRealizadoAsync(novoAgendamento.Id.Value); *@
