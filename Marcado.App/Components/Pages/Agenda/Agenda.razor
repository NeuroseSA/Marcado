    #region Progresso Mensal
private ProgressoDia ObterProgressoDia(DateTime data)
{
    // Verificar se o dia está inativo nas configurações
    if (configuracaoHorario != null && !VerificarDiaAtivoSincrono(data))
    {
        return new ProgressoDia
        {
            Percentual = 0,
            StatusTexto = "Inativo",
            TipoStatus = StatusDia.Inativo,
            StatusCss = "inativo"
        };
    }

    // Se o dia está fechado, retorna 100%
    if (DiasFechados.Contains(data.Date))
    {
        return new ProgressoDia
        {
            Percentual = 100,
            StatusTexto = "Fechado",
            TipoStatus = StatusDia.Fechado,
            StatusCss = "fechado"
        };
    }

    // Calcular progresso baseado nos horários configurados
    var horasDisponiveis = GerarHorasDisponiveis();
    var totalHorarios = horasDisponiveis.Count;
    var agendamentosDia = agendamentosCache.Where(a => a.Data.Date == data.Date).ToList();
    var horariosOcupados = agendamentosDia.Count;

    var percentual = totalHorarios > 0 ? (int)Math.Round((double)horariosOcupados / totalHorarios * 100) : 0;

    ProgressoDia status;
    if (percentual == 0)
    {
        status = new ProgressoDia 
        { 
            Percentual = 0, 
            StatusTexto = "Livre", 
            TipoStatus = StatusDia.Livre,
            StatusCss = "livre"
        };
    }
    else if (percentual >= 100)
    {
        status = new ProgressoDia 
        { 
            Percentual = 100, 
            StatusTexto = "Completo", 
            TipoStatus = StatusDia.Completo,
            StatusCss = "completo"
        };
    }
    else
    {
        status = new ProgressoDia 
        { 
            Percentual = percentual, 
            StatusTexto = $"{horariosOcupados}/{totalHorarios}", 
            TipoStatus = StatusDia.Parcial,
            StatusCss = "parcial"
        };
    }

    return status;
}


    private string ObterCorProgresso(int percentual)
    {
        if (percentual == 0)
            return "#e5e7eb"; // Cinza claro - livre
        else if (percentual <= 25)
            return "#ef4444"; // Vermelho - baixa ocupação
        else if (percentual <= 50)
            return "#f59e0b"; // Amarelo - média ocupação  
        else if (percentual <= 75)
            return "#3b82f6"; // Azul - alta ocupação
        else if (percentual < 100)
            return "#8b5cf6"; // Roxo - quase completo
        else
            return "#10b981"; // Verde - completo/fechado
    }

    private string ObterCorProgresso(ProgressoDia progresso)
    {
        return progresso.TipoStatus switch
        {
            StatusDia.Inativo => "#ec4899", // Rosa - inativo
            StatusDia.Fechado => "#10b981", // Verde - fechado
            _ => ObterCorProgresso(progresso.Percentual)
        };
    }

    // Cache para melhorar performance na visualização mensal
    private List<Agendamento> agendamentosCache = new();

    private async Task CarregarAgendamentosMes()
    {
        var inicioMes = new DateTime(DataSelecionada.Year, DataSelecionada.Month, 1);
        var fimMes = inicioMes.AddMonths(1).AddDays(-1);
        
        // Carregar todos os agendamentos do mês
        agendamentosCache = await _agendamentoServico.ObterAgendamentosAsync(1, null);
        agendamentosCache = agendamentosCache
            .Where(a => a.Data >= inicioMes && a.Data <= fimMes)
            .ToList();
    }
