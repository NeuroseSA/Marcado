@page "/"
@page "/clientes"

@using Marcado.Core.Entidades
@using Marcado.Core.Servicos
@using Marcado.Core.Servicos.Interfaces
@using Marcado.App.Helpers
@inject IClientesServico _clientesServico
@inject EstadoNavegacaoServico _estadoNavegacao

<link href="css/clientes-lista.css" rel="stylesheet" />

<PageTitle>Clientes</PageTitle>

<div class="page-container">
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Meus Clientes</h2>
            <div class="header-actions">
                <div class="search-container">
                    <input type="text" @bind="filtro" @bind:event="oninput" @onkeyup="FiltrarClientes"
                        placeholder="Pesquisar por nome..." class="form-control search-input" />
                </div>
                <button class="btn btn-primary" @onclick="NovoCliente">
                    <span class="desktop-only">Novo Cliente</span>
                    <span class="mobile-only">+</span>
                </button>
            </div>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>E-mail</th>
                    <th>Telefone</th>
                    <th style="width: 200px;">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cliente in clientesFiltrados)
                {
                    <tr>
                        <td>@cliente.Nome</td>
                        <td>@cliente.Email</td>
                        <td>@FormatacaoHelper.FormatarTelefone(cliente.Telefone)</td>
                        <td class="actions">
                            <!-- Botão de Histórico -->
                            <button class="btn btn-info btn-history desktop-only"
                                @onclick="() => VerHistorico(cliente.Id)">Histórico</button>
                            <button class="btn btn-icon btn-history mobile-only" title="Histórico"
                                @onclick="() => VerHistorico(cliente.Id)">📋</button>

                            <!-- Botão de Editar -->
                            <button class="btn btn-outline btn-edit desktop-only"
                                @onclick="() => EditarCliente(cliente.Id)">Editar</button>
                            <button class="btn btn-icon btn-edit mobile-only" title="Editar"
                                @onclick="() => EditarCliente(cliente.Id)">✏️</button>

                            <!-- Botão de Excluir -->
                            <button class="btn btn-secondary btn-delete desktop-only"
                                @onclick="() => ExcluirCliente(cliente.Id)">Excluir</button>
                            <button class="btn btn-icon btn-delete mobile-only" title="Excluir"
                                @onclick="() => ExcluirCliente(cliente.Id)">🗑️</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    int usuarioId = 1; // TODO: mock até ter auth
    string filtro = "";
    List<Marcado.Core.Entidades.Cliente> clientes = new();
    List<Marcado.Core.Entidades.Cliente> clientesFiltrados = new();
    Marcado.Core.Entidades.Cliente clienteEdicao = new();
    bool exibirForm = false;
    [Inject] private NavigationManager Navigation { get; set; } = default!;


    #region Metodos ciclo de vida
    protected override async Task OnInitializedAsync()
    {
        clientes = await _clientesServico.ObterClientesAsync(usuarioId);
        clientesFiltrados = clientes;
    }

    private void FiltrarClientes()
    {
        if (string.IsNullOrWhiteSpace(filtro))
        {
            clientesFiltrados = clientes;
        }
        else
        {
            clientesFiltrados = clientes
            .Where(c => c.Nome.Contains(filtro, StringComparison.OrdinalIgnoreCase))
            .ToList();
        }
        StateHasChanged();
    }

    private void NovoCliente()
    {
        Navigation.NavigateTo("/clientes/novo");
    }

    private void EditarCliente(int id)
    {
        _estadoNavegacao.DefinirClienteParaEdicao(id);
        Navigation.NavigateTo("/clientes/editar");
    }

    private void VerHistorico(int id)
    {
        Navigation.NavigateTo($"/clientes/historico/{id}");
    }

    private async Task ExcluirCliente(int id)
    {
        await _clientesServico.DeletarClienteAsync(id);
        clientes = await _clientesServico.ObterClientesAsync(usuarioId);
        FiltrarClientes();
    }
    #endregion Metodos ciclo de vida
}