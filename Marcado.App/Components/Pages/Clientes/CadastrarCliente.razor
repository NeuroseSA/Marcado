@page "/clientes/novo"
@page "/clientes/editar"

@using Marcado.Core.Entidades
@using Marcado.Core.Servicos
@using Marcado.Core.Servicos.Interfaces
@using Marcado.App.Helpers
@using System.Security.AccessControl
@inject IClientesServico _clientesServico
@inject EstadoNavegacaoServico _estadoNavegacao

<link href="css/cadastro.css" rel="stylesheet" />

<PageTitle>@(isModoEdicao ? "Editar Cliente" : "Novo Cliente")</PageTitle>

<div class="page-container">
    <div class="card">
        <h2 class="card-title">@(isModoEdicao ? "Editar Cliente" : "Cadastrar Cliente")</h2>
        <EditForm Model="@novoCliente" OnValidSubmit="SalvarCliente">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label for="nome">Nome</label>
                <InputText id="nome" class="input" @bind-Value="novoCliente.Nome" />
                <ValidationMessage For="@(() => novoCliente.Nome)" />
            </div>

            <div class="form-group">
                <label for="email">E-mail</label>
                <InputText id="email" class="input" @bind-Value="novoCliente.Email" />
            </div>

            <div class="form-group">
                <label for="telefone">Telefone</label>
                <input id="telefone" class="input" @bind="telefoneFormatado" @bind:event="oninput"
                    @bind:after="AtualizarTelefone" placeholder="(11) 99999-9999" maxlength="15" />
            </div>

            <div class="form-group">
                <label for="Observacao">Observações</label>
                <InputTextArea id="Observacao" class="textarea" @bind-Value="novoCliente.Observacao" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    @(isModoEdicao ? "Atualizar Cliente" : "Adicionar Cliente")
                </button>
                <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private Cliente novoCliente = new();
    private int? ClienteId { get; set; }
    private bool isModoEdicao => ClienteId.HasValue;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    // Propriedade para controlar a máscara do telefone
    private string telefoneFormatado = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        ClienteId = _estadoNavegacao.ObterClienteParaEdicao();

        if (ClienteId.HasValue)
        {
            var clienteExistente = await _clientesServico.ObterClientePorIdAsync(ClienteId.Value);
            if (clienteExistente != null)
            {
                novoCliente = clienteExistente;
                // Formatar o telefone existente
                telefoneFormatado = FormatacaoHelper.FormatarTelefone(novoCliente.Telefone);
            }
            else
            {
                Navigation.NavigateTo("/clientes");
            }
        }
    }

    private void AtualizarTelefone()
    {
        // Aplica a máscara enquanto o usuário digita
        telefoneFormatado = FormatacaoHelper.AplicarMascaraTelefoneInput(telefoneFormatado);

        // Atualiza o valor limpo no modelo
        novoCliente.Telefone = FormatacaoHelper.RemoverMascaraTelefone(telefoneFormatado);

        StateHasChanged();
    }

    private async Task SalvarCliente()
    {
        if (isModoEdicao)
        {
            await _clientesServico.AtualizarClienteAsync(novoCliente);
            Navigation.NavigateTo("/clientes");
            return;
        }
        await _clientesServico.AdicionarClienteAsync(novoCliente);
        Navigation.NavigateTo("/clientes");
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/clientes");
    }
}